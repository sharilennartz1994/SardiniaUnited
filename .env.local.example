# ── Yapla Donation Integration ──────────────────────────────────
# URL della campagna di donazione Yapla.
# Recuperalo da: Yapla  Donazioni  Campagne  [campagna]  Pagina Web  Condivisione  "Promuovi"
NEXT_PUBLIC_YAPLA_DONATE_URL=https://asd-sardinia-united.s2.yapla.com/it/campaign-15376

# Modalità di integrazione Yapla:
#   "true"   iframe incorporato nella pagina (esperienza seamless, ma Yapla lo sconsiglia per potenziali problemi CORS)
#   "false"  redirect a Yapla in nuova tab (raccomandato da Yapla, più stabile)
NEXT_PUBLIC_YAPLA_EMBED=false

# ── Analytics (opzionale) ──────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ── Email newsletter (opzionale - da implementare) ─────────────
RESEND_API_KEY=
